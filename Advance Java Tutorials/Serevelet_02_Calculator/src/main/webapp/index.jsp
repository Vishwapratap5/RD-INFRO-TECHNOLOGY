<html>
<body>
<h2 style="color: brown">Calculator App</h2>
<form action="calculate" method="get">
    <table>
        <tr>
            <td>
                <label for="Num1">Enter First Number :</label>
                <input id="Num1" type="number" name="num1" placeholder="First Number">
            </td>
        </tr>

        <tr>
            <td>
                <label for="Num2">Enter Second Number :</label>
                <input id="Num2" type="number" name="num2" placeholder="Second Number">
            </td>
        </tr>

        <tr>
            <td>
                <label for="operation">Enter Operation :</label>
                <input id="operation" type="text" name="operation" placeholder="Arithmatic Operation">
            </td>
        </tr>

        <tr>
            <td>
                <input type="submit" value="calculate">
            </td>
        </tr>
    </table>
</form>
</body>
</html>
